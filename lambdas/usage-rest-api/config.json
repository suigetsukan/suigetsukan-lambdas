{
  "function_name_suffix": "usage-rest-api",
  "function_name": "suigetsukan-usage-rest-api",
  "handler": "app.lambda_handler",
  "runtime": "python3.12",
  "timeout": 60,
  "memory_size": 256,
  "env_vars": {
    "AWS_REGION": "placeholder",
    "AWS_COGNITO_USER_POOL_ID": "optional",
    "RUM_REGION": "optional",
    "COGNITO_METRICS_REGION": "optional",
    "RUM_APP_MONITOR_NAME": "optional",
    "RUM_LOG_GROUP": "optional",
    "CORS_ALLOWED_ORIGIN": "optional",
    "REQUIRE_AUTHORIZER": "optional"
  },
  "optional_env_vars": [
    "RUM_REGION",
    "COGNITO_METRICS_REGION",
    "RUM_APP_MONITOR_NAME",
    "RUM_LOG_GROUP",
    "CORS_ALLOWED_ORIGIN",
    "REQUIRE_AUTHORIZER"
  ],
  "layers": [],
  "tags": {"Project": "suigetsukan-curriculum", "Environment": "prod"},
  "role_name": "suigetsukan-usage-rest-api-role",
  "exclude_files": ["*.pyc", "__pycache__/*", "tests/**"]
}
